---
import BaseLayout from '@/layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
const u = (p: string) => (base + p).replace(/\/{2,}/g, '/');
---
<BaseLayout title="Home">
  <h1>Ciao Thomas 👋</h1>
  <p>
    Questo è il tuo posto unico per preparare il <strong>semestre filtro di Veterinaria</strong>
    (Fisica, Biologia, Chimica). L'obiettivo è uno solo: <strong>capire bene ogni concetto</strong>,
    spiegato semplice, con schemi e video — e poi allenarlo.
  </p>

  <div class="cards">
    <a class="card" href={u('tutorial/')}>
      <div class="emoji">🧭</div>
      <h3>Tutorial</h3>
      <p>Come funziona il sito e come studiare al meglio. Parti da qui.</p>
    </a>
    <a class="card" href={u('risorse/')}>
      <div class="emoji">📚</div>
      <h3>Risorse</h3>
      <p>Tutti i concetti spiegati semplici, in ordine, con diagrammi e video.</p>
    </a>
    <a class="card soon" href={u('studio/')}>
      <div class="emoji">🎯</div>
      <h3>Studio <span class="badge-soon">in arrivo</span></h3>
      <p>Flashcard e ripasso intelligente per fissare tutto nel tempo.</p>
    </a>
  </div>

  <!-- Promemoria pratico per Thomas: come tenerlo a portata e come funziona il salvataggio -->
  <section class="promemoria">
    <h2>📌 Due cose pratiche (leggile una volta)</h2>
    <ul>
      <li>
        <strong>📱 Tienilo sempre a portata.</strong> Salva questa pagina nei <strong>preferiti</strong>,
        o meglio: dal telefono fai <em>«Aggiungi alla schermata Home»</em> — così lo apri come una vera app,
        anche al volo tra un'ora e l'altra.
      </li>
      <li>
        <strong>💾 I progressi si salvano da soli.</strong> Non devi <em>mai</em> fare "salva", "esporta"
        o "importa": ogni flashcard e ogni spunta restano lì in automatico, anche se chiudi tutto.
      </li>
      <li>
        <strong>🔒 Una sola accortezza:</strong> i progressi vivono su <strong>questo dispositivo e
        questo browser</strong>. Studia sempre dallo stesso posto (es. sempre dal telefono). Se cambi
        telefono/PC o cancelli i dati del browser, riparti da zero — quindi non svuotare la cronologia "tutto".
      </li>
    </ul>
    <p class="pm-note">Se più avanti arrivano aggiornamenti o nuove materie, il tuo storico <strong>resta intatto</strong>: continui da dove eri. 🏴‍☠️</p>
  </section>

  <style>
    .promemoria {
      margin-top: 2rem;
      background: var(--brand-soft);
      border: 1px solid var(--border);
      border-left: 4px solid var(--brand);
      border-radius: var(--radius);
      padding: 1rem 1.2rem;
    }
    .promemoria h2 { margin: .2rem 0 .6rem; font-size: 1.15rem; }
    .promemoria ul { margin: 0; padding-left: 1.1rem; }
    .promemoria li { margin: .45rem 0; line-height: 1.55; }
    .pm-note { margin: .8rem 0 .2rem; font-size: .92rem; color: var(--muted); }
  </style>
</BaseLayout>
